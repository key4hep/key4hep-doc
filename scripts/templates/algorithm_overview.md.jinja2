# Algorithm Overview

This page lists all Gaudi algorithms available in the Key4hep software stack,
collected from the active environment. Use the search box to filter by algorithm
name, package, or library. Click a package header to collapse or expand it; click
an algorithm name to reveal its properties.

Total: **{{ total_algorithms }} algorithms** across **{{ total_packages }} packages**.

```{raw} html
<style>
{% include "_overview_common.css.jinja2" %}
#algorithm-overview .alg-package-group {
  margin-bottom: 0.6em;
  border: 1px solid #ddd;
  border-radius: 4px;
  overflow: hidden;
}
#algorithm-overview .alg-package-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.45em 0.8em;
  background: #f0f0f0;
  cursor: pointer;
  user-select: none;
}
#algorithm-overview .alg-package-header:hover {
  background: #e5e5e5;
}
#algorithm-overview .alg-package-name {
  font-weight: bold;
  font-family: monospace;
  font-size: 0.95em;
}
#algorithm-overview .alg-package-meta {
  display: flex;
  align-items: center;
  gap: 0.5em;
  font-size: 0.83em;
  color: #555;
}
#algorithm-overview .alg-package-toggle {
  display: inline-block;
  transition: transform 0.15s;
  font-size: 0.75em;
}
#algorithm-overview .alg-package-group.collapsed .alg-package-toggle {
  transform: rotate(-90deg);
}
#algorithm-overview .alg-cards-container {
  padding: 0.4em;
}
#algorithm-overview .alg-package-group.collapsed .alg-cards-container {
  display: none;
}
#algorithm-overview .alg-card-right {
  display: flex;
  align-items: center;
  gap: 0.4em;
}
#algorithm-overview .alg-lib-badge {
  font-size: 0.73em;
  background: #ddeeff;
  color: #224;
  padding: 0.1em 0.45em;
  border-radius: 3px;
  font-family: monospace;
}
</style>

<div id="algorithm-overview">
  <div class="alg-filter-bar">
    <input type="text" id="alg-search" placeholder="Filter by name, package, or library…" autocomplete="off" />
    <span id="alg-stats">Showing {{ total_algorithms }} of {{ total_algorithms }} algorithms in {{ total_packages }} packages</span>
  </div>

  {%- for package, algorithms in packages.items() %}
  <div class="alg-package-group" data-package="{{ package | e }}">
    <div class="alg-package-header">
      <span class="alg-package-name">{{ package | e }}</span>
      <span class="alg-package-meta">
        <span class="alg-package-count">{{ algorithms | length }} algorithm{%- if algorithms | length != 1 %}s{%- endif %}</span>
        <span class="alg-package-toggle">&#9660;</span>
      </span>
    </div>
    <div class="alg-cards-container">
      {%- for alg in algorithms %}
      <div class="alg-card" data-name="{{ alg.name | e }}" data-lib="{{ alg.lib | e }}" data-package="{{ package | e }}">
        <div class="alg-card-header">
          <span class="alg-name">{{ alg.name | e }}</span>
          <span class="alg-card-right">
            <span class="alg-lib-badge">{{ alg.lib | e }}</span>
            <span class="alg-card-toggle">&#9658;</span>
          </span>
        </div>
        <div class="alg-card-body">
          {%- if alg.properties %}
          <table class="alg-props-table">
            <thead>
              <tr>
                <th>Property</th>
                <th>Default</th>
                <th>Description</th>
              </tr>
            </thead>
            <tbody>
              {%- for prop_name, prop_info in alg.properties.items() %}
              <tr>
                <td><code>{{ prop_name | e }}</code></td>
                <td>{{ prop_info.value | render_prop_value }}</td>
                <td>{{ prop_info.description | e }}</td>
              </tr>
              {%- endfor %}
            </tbody>
          </table>
          {%- else %}
          <em>No properties available.</em>
          {%- endif %}
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>
  {%- endfor %}
</div>

<script>
(function () {
  var totalAlgorithms = {{ total_algorithms }};
  var totalPackages = {{ total_packages }};

  var searchInput = document.getElementById('alg-search');
  var statsEl = document.getElementById('alg-stats');
  var overview = document.getElementById('algorithm-overview');

  // Toggle package group collapse/expand
  overview.querySelectorAll('.alg-package-header').forEach(function (header) {
    header.addEventListener('click', function () {
      header.closest('.alg-package-group').classList.toggle('collapsed');
    });
  });

  // Toggle algorithm card expand/collapse
  overview.querySelectorAll('.alg-card-header').forEach(function (header) {
    header.addEventListener('click', function () {
      header.closest('.alg-card').classList.toggle('expanded');
    });
  });

  function debounce(fn, delay) {
    var timer;
    return function () {
      clearTimeout(timer);
      timer = setTimeout(fn, delay);
    };
  }

  function updateStats(visibleCards, visiblePackages) {
    statsEl.textContent =
      'Showing ' + visibleCards + ' of ' + totalAlgorithms +
      ' algorithms in ' + visiblePackages + ' packages';
  }

  function filterCards() {
    var query = searchInput.value.trim().toLowerCase();
    var visibleCards = 0;

    overview.querySelectorAll('.alg-card').forEach(function (card) {
      if (!query) {
        card.style.display = '';
        visibleCards++;
        return;
      }
      var name = (card.dataset.name || '').toLowerCase();
      var lib  = (card.dataset.lib  || '').toLowerCase();
      var pkg  = (card.dataset.package || '').toLowerCase();
      var matches = name.indexOf(query) !== -1 ||
                    lib.indexOf(query)  !== -1 ||
                    pkg.indexOf(query)  !== -1;
      card.style.display = matches ? '' : 'none';
      if (matches) visibleCards++;
    });

    var visiblePackages = 0;
    overview.querySelectorAll('.alg-package-group').forEach(function (group) {
      var anyVisible = false;
      group.querySelectorAll('.alg-card').forEach(function (c) {
        if (c.style.display !== 'none') anyVisible = true;
      });
      group.style.display = anyVisible ? '' : 'none';
      if (anyVisible) visiblePackages++;
    });

    updateStats(visibleCards, visiblePackages);
  }

  searchInput.addEventListener('input', debounce(filterCards, 200));

  // URL hash deep-linking: #AlgorithmName expands and scrolls to that card
  function handleHash() {
    var hash = decodeURIComponent(window.location.hash.slice(1));
    if (!hash) return;
    var target = null;
    overview.querySelectorAll('.alg-card').forEach(function (c) {
      if (c.dataset.name === hash) target = c;
    });
    if (!target) return;
    var group = target.closest('.alg-package-group');
    if (group) group.classList.remove('collapsed');
    target.classList.add('expanded');
    setTimeout(function () {
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 100);
  }

  window.addEventListener('hashchange', handleHash);
  handleHash();

  updateStats(totalAlgorithms, totalPackages);
})();
</script>
```
